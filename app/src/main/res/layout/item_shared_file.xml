<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@android:color/white"
    android:elevation="2dp"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/sharedFileNameText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="OS_Lecture.pdf"
        android:textColor="#1A1A1A"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/sharedFileMetaText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="5.4 MB • Documents • DOWNLOADED"
        android:textColor="#757575"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/sharedFileHashText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="SHA-256: abcdef1234567890..."
        android:textColor="#673AB7"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/sharedFileTagsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Tags"
        android:textColor="#555555"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/deleteSharedFileBtn"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:backgroundTint="#EEEEEE"
            android:text="Remove"
            android:textAllCaps="false"
            android:textColor="#333333"
            android:textSize="12sp" />

        <Button
            android:id="@+id/openSharedFileBtn"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#673AB7"
            android:text="Open"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
