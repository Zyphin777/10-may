<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_nearby_map.xml — Fully offline peer map edition
  Replace the previous version of this file entirely.
  This version does not use OpenStreetMap tiles. It draws nearby peers directly.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fully offline peer map: no external tiles, no internet required -->
    <com.example.offlineroutingapp.OfflinePeerMapView
        android:id="@+id/offlineMapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true" />

    <!-- Top bar overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp">

        <ImageButton
            android:id="@+id/btnMapBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="@drawable/bg_circle_white"
            android:elevation="4dp"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvOnlineCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="No users nearby"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@drawable/bg_pill_purple"
            android:elevation="4dp" />

    </LinearLayout>

    <!-- Peer bottom sheet (hidden by default) -->
    <LinearLayout
        android:id="@+id/bottomSheetPeer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_sheet"
        android:padding="20dp"
        android:layout_gravity="bottom"
        android:translationY="400dp"
        android:visibility="gone"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPeerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User Name"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />

                <TextView
                    android:id="@+id/tvPeerDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calculating..."
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginTop="2dp" />

            </LinearLayout><ImageButton
            android:id="@+id/btnClosePeerSheet"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@android:color/transparent"
            android:contentDescription="Close" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChatWithPeer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Open Chat"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:backgroundTint="#673AB7"
            app:cornerRadius="26dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>