<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F5FA"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/publicRequestsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Public Requests"
        android:textColor="#1A1A1A"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/publicRequestsSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Ask nearby users for files or data offline."
        android:textColor="#757575"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_message_input"
        android:orientation="horizontal"
        android:padding="8dp">

        <EditText
            android:id="@+id/requestInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Example: Need OS lecture PDF"
            android:imeOptions="actionSend"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="3"
            android:minHeight="48dp"
            android:padding="8dp"
            android:textColor="#1A1A1A"
            android:textColorHint="#9E9E9E"
            android:textSize="14sp" />

        <Button
            android:id="@+id/sendRequestBtn"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="bottom"
            android:backgroundTint="#673AB7"
            android:text="Send"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/requestsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/emptyRequestsText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No public requests yet\nWrite the first offline request."
        android:textColor="#757575"
        android:textSize="15sp" />

</LinearLayout>
