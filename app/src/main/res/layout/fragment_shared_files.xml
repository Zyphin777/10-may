<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F5FA"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Shared Files"
        android:textColor="#1A1A1A"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/cacheSummaryText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="0 shared file(s)"
        android:textColor="#757575"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/sharedFilesSearchInput"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_message_input"
        android:hint="Search cached files, tags, category, hash..."
        android:inputType="text"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="#1A1A1A"
        android:textColorHint="#9E9E9E"
        android:textSize="14sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/sharedFilesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/emptySharedFilesText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No shared files yet\nDownloaded files and selected files will appear here."
        android:textColor="#757575"
        android:textSize="15sp" />

</LinearLayout>
